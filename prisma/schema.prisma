generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  displayName String
  email       String   @unique
  password    String   // bcrypt hash
  createdAt   DateTime @default(now())
}

model Race {
  id          String   @id
  name        String
  venue       String
  country     String
  date        DateTime
  discipline  String
  gender      String   // "M" or "W"
  status      String   @default("upcoming") // "upcoming" | "completed"
  results     Result[]
  predictions Prediction[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Athlete {
  id         String   @id
  name       String
  nationCode String
  gender     String?  // "M" or "W"
  results    Result[]
}

model Result {
  id        String  @id @default(cuid())
  raceId    String
  athleteId String
  rank      Int?    // null = DNF/DSQ
  race      Race    @relation(fields: [raceId], references: [id])
  athlete   Athlete @relation(fields: [athleteId], references: [id])

  @@unique([raceId, athleteId])
}

model Group {
  id          String            @id @default(cuid())
  name        String
  inviteCode  String            @unique @default(cuid())
  createdBy   String            // User.id
  createdAt   DateTime          @default(now())
  members     GroupMembership[]
  predictions Prediction[]
}

model GroupMembership {
  id       String   @id @default(cuid())
  userId   String   // User.id
  groupId  String
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

// Scoring: 3 pts if predicted 1st = actual 1st
//          +1 pt if predicted 2nd appears anywhere in actual top 3
//          +1 pt if predicted 3rd appears anywhere in actual top 3
model Prediction {
  id        String   @id @default(cuid())
  userId    String   // User.id
  raceId    String
  groupId   String
  first     String   // athlete/team ID
  second    String
  third     String
  score     Int?     // null until race is completed and scored
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  race      Race     @relation(fields: [raceId], references: [id])
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, raceId, groupId])
}
